        '[OvtQvLBqAUCw6gl7OgXbj]:code "Code"':
          data:
            allowConsole: false
            allowFetch: false
            allowProcess: false
            allowRequire: false
            allowRivet: false
            code: >-
              const csv = inputs.input.value.trim();

              const lines = csv.split('\n');


              // Parse CSV header

              const header = lines[0].split(',').map(h => h.trim());

              const assetClassIdx = header.indexOf('Asset class');

              const assetIdx = header.indexOf('Asset');

              const currentPriceIdx = header.indexOf('Current price');

              const lastMonthPriceIdx = header.indexOf('Last month price');


              if (assetClassIdx === -1 || assetIdx === -1 || currentPriceIdx === -1 || lastMonthPriceIdx === -1) {
                  return {
                      output: {
                          type: 'string',
                          value: 'CSV inválido: colunas necessárias não encontradas.'
                      }
                  };
              }


              // Parse data rows

              const data = lines.slice(1).map(line => {
                  const cols = line.split(',').map(c => c.trim());
                  return {
                      assetClass: cols[assetClassIdx],
                      asset: cols[assetIdx],
                      currentPrice: parseFloat(cols[currentPriceIdx]),
                      lastMonthPrice: parseFloat(cols[lastMonthPriceIdx])
                  };
              });


              // Calculate returns per asset

              const returns = data.map(({ assetClass, asset, currentPrice, lastMonthPrice }) => {
                  const ret = lastMonthPrice === 0 ? 0 : ((currentPrice - lastMonthPrice) / lastMonthPrice) * 100;
                  return { assetClass, asset, return: ret };
              });


              // Group by asset class and calculate average return

              const grouped = {};

              returns.forEach(({ assetClass, return: ret }) => {
                  if (!grouped[assetClass]) grouped[assetClass] = [];
                  grouped[assetClass].push(ret);
              });


              const avgByClass = {};

              for (const cls in grouped) {
                  const arr = grouped[cls];
                  const avg = arr.reduce((a, b) => a + b, 0) / arr.length;
                  avgByClass[cls] = avg;
              }


              // Calculate overall average return

              const allReturns = returns.map(r => r.return);

              const overallAvg = allReturns.reduce((a, b) => a + b, 0) / allReturns.length;


              let summary = 'Resumo de Retornos por Classe de Ativo:\n';

              for (const cls in avgByClass) {
                  summary += `- ${cls}: ${avgByClass[cls].toFixed(2)}%\n`;
              }


              summary += '\nDetalhes por ativo:\n';

              returns.forEach(({ asset, return: ret }) => {
                  const sinal = ret >= 0 ? '+' : '';
                  summary += `- ${asset}: ${sinal}${ret.toFixed(2)}%\n`;
              });


              summary += `\nRetorno médio geral: ${overallAvg.toFixed(2)}%\n`;


              return {
                  output: {
                      type: 'string',
                      value: summary
                  }
              };
            inputNames:
              - input
            outputNames:
              - output
