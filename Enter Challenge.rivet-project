            code: >-
              const csv = inputs.input1.value.trim();

              const lines = csv.split('\n').filter(l => l.trim());


              const header = lines[0].split(',').map(h => h.trim());

              const tickerIdx = header.indexOf('ticker');

              const dyIdx = header.indexOf('dy_percent');

              const classIdx = header.indexOf('classification');

              const inPortfolioIdx = header.indexOf('in_portfolio');


              if (tickerIdx === -1 || dyIdx === -1) {
                  return {
                      output1: {
                          type: 'string',
                          value: 'CSV inválido: colunas necessárias não encontradas.'
                      }
                  };
              }


              const data = lines.slice(1).map(line => {
                  const cols = line.split(',').map(c => c.trim());
                  return {
                      ticker: cols[tickerIdx],
                      dy: parseFloat(cols[dyIdx]),
                      classification: cols[classIdx],
                      inPortfolio: cols[inPortfolioIdx] === 'yes'
                  };
              });


              const portfolioAssets = data.filter(d => d.inPortfolio);

              const candidates = data.filter(d => !d.inPortfolio);


              let summary = 'Dividend Yield Analysis (Source: Status Invest, Feb 2025):\n\n';


              summary += '=== ASSETS IN PORTFOLIO ===\n';

              portfolioAssets.forEach(({ ticker, dy, classification }) => {
                  const flag = classification === 'regular' ? '✅' : 
                               classification === 'irregular' ? '⚠️' : '❌';
                  summary += `- ${ticker}: DY ${dy.toFixed(2)}% ${flag} (${classification})\n`;
              });


              summary += '\n=== BUY CANDIDATES (not in portfolio) ===\n';

              candidates
                  .sort((a, b) => b.dy - a.dy)
                  .forEach(({ ticker, dy, classification }) => {
                      const flag = classification === 'regular' ? '✅' : 
                                   classification === 'irregular' ? '⚠️' : '❌';
                      summary += `- ${ticker}: DY ${dy.toFixed(2)}% ${flag} (${classification})\n`;
                  });

              return {
                  output1: {
                      type: 'string',
                      value: summary
                  }
              };
            inputNames: input1
