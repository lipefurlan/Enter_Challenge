        '[kkjlZzQ4r3VIsWkmyRHib]:code "Equity Signal Analyzer"':
          data:
            allowConsole: false
            allowFetch: false
            allowProcess: false
            allowRequire: false
            allowRivet: false
            code: >
              // ============================================================

              // EQUITY ANALYZER

              // Input 1: profitability_csv | Input 2: portfolio_text | Input 3: dividend_csv

              // Output 1: portfolio_results → Prompt 1

              // Output 2: equity_signals   → Prompt 4

              // ============================================================


              // ---- PART 1: Monthly returns from CSV ----

              const csv = inputs.profitability_csv.value.trim();

              const lines = csv.split('\n');

              const header = lines[0].split(',').map(h => h.trim());

              const assetIdx = header.indexOf('Asset');

              const currentPriceIdx = header.indexOf('Current price');

              const lastMonthPriceIdx = header.indexOf('Last month price');

              const assetClassIdx = header.indexOf('Asset class');


              const returns = lines.slice(1).map(line => {
                const cols = line.split(',').map(c => c.trim());
                const cur = parseFloat(cols[currentPriceIdx]);
                const prev = parseFloat(cols[lastMonthPriceIdx]);
                return {
                  assetClass: cols[assetClassIdx],
                  asset: cols[assetIdx],
                  return: prev === 0 ? 0 : ((cur - prev) / prev) * 100
                };
              });


              // Average by class

              const grouped = {};

              returns.forEach(({ assetClass, return: ret }) => {
                if (!grouped[assetClass]) grouped[assetClass] = [];
                grouped[assetClass].push(ret);
              });

              const overallAvg = returns.map(r => r.return).reduce((a, b) => a + b, 0) / returns.length;


              let portfolioResults = 'Monthly Return Summary by Asset Class:\n';

              for (const cls in grouped) {
                const avg = grouped[cls].reduce((a, b) => a + b, 0) / grouped[cls].length;
                portfolioResults += `- ${cls}: ${avg.toFixed(2)}%\n`;
              }

              portfolioResults += '\nDetails per asset:\n';

              returns.forEach(({ asset, return: ret }) => {
                portfolioResults += `- ${asset}: ${ret >= 0 ? '+' : ''}${ret.toFixed(2)}%\n`;
              });

              portfolioResults += `\nOverall average return: ${overallAvg.toFixed(2)}%\n`;


              // ---- PART 2: Historical returns from portfolio_text ----

              const knownTickers = ['LREN3','MRFG3','ARZZ3','HAPV3'];

              const pLines = inputs.portfolio_text.value.split('\n').map(l => l.trim()).filter(l => l);

              const historical = {};


              for (let i = 0; i < pLines.length; i++) {
                if (knownTickers.includes(pLines[i])) {
                  const histLine = pLines[i + 3] || '';
                  const match = histLine.match(/^(-?\d+[,.]?\d*)%$/);
                  if (match) historical[pLines[i]] = parseFloat(match[1].replace(',', '.'));
                }
              }


              // ---- PART 3: Dividend data ----

              const divMap = {};

              const divLines = inputs.dividend_csv.value.trim().split('\n');

              const divHeader = divLines[0].split(',').map(h => h.trim());

              const tickerIdx  = divHeader.indexOf('ticker');

              const dyIdx      = divHeader.indexOf('dy_percent');

              const classIdx   = divHeader.indexOf('classification');


              divLines.slice(1).forEach(line => {
                if (!line.trim()) return;
                const cols = line.split(',').map(c => c.trim());
                divMap[cols[tickerIdx]] = {
                  dy: parseFloat(cols[dyIdx]) || 0,
                  classification: cols[classIdx] || 'unknown'
                };
              });


              // ---- PART 4: Signal logic ----

              function getSignal(hist, month) {
                if (hist < -50 && month > 30)          return 'HOLD — volatile recovery from crash, reassess next month';
                if (hist < -30 && month < 0)           return 'SELL — deep loss accelerating, no recovery signal';
                if (hist < -15 && month < 0)           return 'SELL — position deteriorating, consider cutting losses';
                if (hist < -30 && Math.abs(month) < 2) return 'SELL — deep loss with no meaningful recovery signal';
                if (hist < 0   && month > 10)          return 'HOLD — recovering from loss, monitor closely';
                if (hist < -30 && month > 0)           return 'HOLD — deep loss, slow recovery, watch sustainability';
                if (hist > 0   && month < -15)         return 'REDUCE — profit at risk, protect gains';
                if (hist > 0   && month < 0)           return 'HOLD — profitable, normal volatility';
                if (hist > 0   && month > 0)           return 'HOLD — strong position, consider adding on dips';
                return 'HOLD — monitor position';
              }


              // ---- PART 5: Build equity_signals ----

              let equitySignals = 'Equity Signal Analysis (Historical x Monthly x Dividend):\n\n';

              equitySignals += 'ASSET | MONTHLY | HISTORICAL | SIGNAL | DY% | DIVIDEND\n';

              equitySignals += '------|---------|------------|--------|-----|----------\n';


              returns.forEach(({ asset, return: month }) => {
                const hist   = historical[asset];
                const div    = divMap[asset];
                const histLabel  = hist !== undefined ? (hist >= 0 ? '+' : '') + hist.toFixed(1) + '%' : 'N/A';
                const monthLabel = (month >= 0 ? '+' : '') + month.toFixed(2) + '%';
                const signal     = hist !== undefined ? getSignal(hist, month) : 'BUY CANDIDATE — not currently held in portfolio';
                const dyLabel    = div ? (div.dy > 0 ? div.dy.toFixed(2) + '%' : '0%') : 'N/A';
                const divClass   = div ? div.classification : 'N/A';
                equitySignals += `${asset} | ${monthLabel} | ${histLabel} | ${signal} | ${dyLabel} | ${divClass}\n`;
              });


              return {
                equity_signals: { type: 'string', value: equitySignals }
              };
            inputNames:
              - portfolio_text
              - profitability_csv
              - dividend_csv
            outputNames:
              - equity_signals
          outgoingConnections:
            - equity_signals->"Prompt - Buy/Sell"
              VUyGoJpSkRmx4BKOTWVW-/equity_signals
